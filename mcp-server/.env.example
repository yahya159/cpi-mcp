# SAP BTP Integration Suite / Process Integration Runtime credentials.
# Obtain these from a service key on a "Process Integration Runtime" service instance.
#
# IMPORTANT: use the "api" plan (grants OData API / monitoring access), NOT
# "integration-flow" (that is for sending messages to deployed iFlows at runtime;
# its token is rejected by /api/v1/... with 401).

# Base URL of the CPI OData API = the "url" field from the api-plan service key.
# This is the Tenant Management Node host (no "-rt"), without a trailing slash.
# Example: https://<tenant-id>.it-cpitrial05.cfapps.us10-001.hana.ondemand.com
CPI_API_BASE_URL=

# OAuth2 token endpoint = the "tokenurl" field from the service key
# Example: https://<subdomain>.authentication.us10.hana.ondemand.com/oauth/token
CPI_TOKEN_URL=

# OAuth2 client credentials = "clientid" and "clientsecret" from the service key
CPI_CLIENT_ID=
CPI_CLIENT_SECRET=
