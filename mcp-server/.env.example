# SAP BTP Integration Suite / Process Integration Runtime credentials
# Obtain these from your SAP BTP service key for the "Process Integration Runtime" service instance.
# Required plan: "integration-flow" with role "MonitoringDataRead" (or equivalent).

# Base URL of your CPI tenant OData API (without trailing slash)
# Example: https://<tenant-id>.it-cpi018.cfapps.eu10.hana.ondemand.com
CPI_API_BASE_URL=

# OAuth2 token endpoint from the service key
# Example: https://<subdomain>.authentication.eu10.hana.ondemand.com/oauth/token
CPI_TOKEN_URL=

# OAuth2 client credentials from the service key
CPI_CLIENT_ID=
CPI_CLIENT_SECRET=
