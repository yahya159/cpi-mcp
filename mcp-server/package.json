{
  "name": "sap-cpi-monitoring-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for SAP Integration Suite / CPI monitoring",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sap-cpi-monitoring-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "public",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev:http": "tsc && node dist/http.js",
    "web": "tsc && node dist/web.js",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@sap/hana-client": "^2.21.27"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
